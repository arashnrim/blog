---
import Hero from "@components/Hero.astro";
import PostCard from "@components/PostCard.astro";
import Prompt from "@components/Prompt.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

let posts = await getCollection("posts");
posts = posts.sort((a, b) => {
  const aDate = a.data.updatedDate || a.data.publishedDate;
  const bDate = b.data.updatedDate || b.data.publishedDate;
  if (aDate && bDate) {
    return new Date(bDate).valueOf() - new Date(aDate).valueOf();
  } else if (aDate) {
    return -1;
  } else if (bDate) {
    return 1;
  } else {
    return 0;
  }
});
---

<BaseLayout>
  <Hero>
    <h1 id="hero__title" class="logo">function()</h1>
    <p id="hero__description">
      <a href="https://arash.codes" rel="noopener noreferrer" target="_blank"
        >Arash's</a
      > blog: a space for the gathering of thoughts, experiences, and reflections
      as an aspiring technologist, introspective human, and lifelong student.
    </p>
  </Hero>

  <section id="preface" class="container">
    <p>
      To me, writing is an avenue to self-improvement — it allows me to think
      through things and form opinions, to vent, and to explore. It's something
      I want to remain close to, so this blog is one of several ways I'm keeping
      this close to heart.
    </p>

    <p>
      I'm open to writing about anything I'm curious about, and many ideas I've
      written so far come from the spur of the moment. You might find <a
        href="/topics/code">in-depth technical posts</a
      > talking about something that interests me just as much as you could <a
        href="/topics/reflection">ones reflecting</a
      > on my place in the world. I hope both intrigue and engage!
    </p>

    <p>
      Truly: thank you for stopping by, even if it's just for a bit. If there's
      something you're curious about here, <a
        href="https://arash.codes/#connect"
        rel="noopener noreferrer"
        target="_blank">feel free to reach out</a
      > so we can have a chat about it!
    </p>

    <p>
      <a href="/rss.xml"
        >Are you using <abbr title="Really Simple Syndication">RSS</abbr>?</a
      >
    </p>

    <Prompt title="Two halves, one ecosystem" icon="ph:plant" kind="muted">
      <p style="margin: 0">
        I’m trying out something new to bring this and my <a
          href="https://garden.arash.codes">digital garden</a
        > together as <a
          href="https://garden.arash.codes/meta/two-halves-one-ecosystem"
          >sister projects</a
        > that frequently interact with each other. Watch this space as I move things
        about and figure stuff out!
      </p>
    </Prompt>

    <!-- <section id="search-container">
      <Search />
    </section> -->
  </section>

  <section id="posts" class="container">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>

<style>
  #hero__title {
    font-size: var(--title);
    margin: 0 0 0.25em 0;
  }

  #hero__description {
    margin: 0;
  }

  #posts {
    padding-top: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  @media screen and (min-width: 1024px) {
    #posts {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1536px) {
    #posts {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
